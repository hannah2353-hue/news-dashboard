# Turso (Cloud SQLite)
# 로컬 개발 시에는 비워두면 ./data/news.db 로컬 파일을 사용합니다.
# Vercel 배포 시에는 반드시 값을 입력하세요.
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Google Gemini API (LLM 기사 분석) — 무료
# https://aistudio.google.com 에서 "Get API Key" 클릭하여 발급
GEMINI_API_KEY=AIzaSy...

# Telegram Bot (알림 발송)
TELEGRAM_BOT_TOKEN=1234567890:AAF...
TELEGRAM_CHAT_ID=123456789

# 매일 아침 요약에 포함될 대시보드 링크 (Vercel 배포 후 주소)
DASHBOARD_URL=https://your-app.vercel.app

# Vercel Cron 엔드포인트 보호용 시크릿 (임의의 긴 랜덤 문자열)
CRON_SECRET=
